# ===========================================
# SpectrAI Community Platform - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# ===========================================
# Database (PostgreSQL)
# ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=spectrai_community
POSTGRES_PORT=5432

# Docker Compose 内部使用的数据库连接字符串
# 格式：postgresql://用户:密码@服务名:端口/数据库名
DATABASE_URL=postgresql://postgres:your_secure_password_here@postgres:5432/spectrai_community

# ===========================================
# Redis
# ===========================================
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ===========================================
# GitHub OAuth (用于用户登录)
# ===========================================
# 在 https://github.com/settings/developers 创建 OAuth App
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# GitHub OAuth 回调地址 (开发环境)
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

# ===========================================
# JWT (JSON Web Token 签名密钥)
# ===========================================
# ⚠️ 生产环境务必使用强随机字符串 (至少 32 字符)
# 生成命令：openssl rand -base64 32
JWT_SECRET=your_super_secret_jwt_signing_key_here_change_in_production

# JWT 过期时间 (默认 7 天)
JWT_EXPIRES_IN=7d

# ===========================================
# 应用配置
# ===========================================
NODE_ENV=development

# API 服务端口
API_PORT=3001

# Web 服务端口
WEB_PORT=3000

# ===========================================
# 前端公共 URL (Next.js 需要)
# ===========================================
# API 基础 URL (前端调用后端)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# 应用公共 URL (用于生成分享链接等)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# 可选配置
# ===========================================
# 日志级别 (debug, info, warn, error)
LOG_LEVEL=info

# CORS 允许的源 (开发环境可设为 *)
CORS_ORIGIN=http://localhost:3000

# Session 配置
SESSION_SECRET=your_session_secret_here

# 文件上传限制 (MB)
MAX_UPLOAD_SIZE=10

# Rate Limiting (每分钟请求数)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
