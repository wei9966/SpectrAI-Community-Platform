{
  "name": "@spectrai-community/root",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @spectrai-community/web dev",
    "dev:api": "pnpm --filter @spectrai-community/api dev",
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @spectrai-community/shared build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean",
    "db:migrate": "pnpm --filter @spectrai-community/api db:migrate",
    "db:generate": "pnpm --filter @spectrai-community/api db:generate",
    "db:push": "pnpm --filter @spectrai-community/api db:push",
    "db:seed": "pnpm --filter @spectrai-community/api db:seed",
    "db:studio": "pnpm --filter @spectrai-community/api db:studio"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^15.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/ui": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}